+#define GC2607_GAIN_MIN			64	/* 1.0x */
+#define GC2607_GAIN_MAX			255	/* maps to LUT index 16 */
+#define GC2607_GAIN_STEP		1
+#define GC2607_GAIN_DEFAULT		GC2607_GAIN_MIN
+#define GC2607_DGAIN_MIN		0
