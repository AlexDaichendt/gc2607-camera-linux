+static unsigned int gc2607_gain_to_lut_index(int gain)
+{
+	if (gain <= GC2607_GAIN_MIN)
+		return 0;
+
+	if (gain >= GC2607_GAIN_MAX)
+		return GC2607_GAIN_TABLE_SIZE - 1;
+
+	return (gain - GC2607_GAIN_MIN) * (GC2607_GAIN_TABLE_SIZE - 1) /
+	       (GC2607_GAIN_MAX - GC2607_GAIN_MIN);
+}
