diff --git a/Makefile b/Makefile
index 9eabbfc..1489c50 100644
--- a/Makefile
+++ b/Makefile
@@ -12,18 +12,21 @@ KDIR ?= /lib/modules/$(shell uname -r)/build
 # Build directory
 PWD := $(shell pwd)
 
+# Auto-detect kernels built with LLVM/Clang (e.g. CachyOS)
+KBUILD_COMPILER := $(shell grep -q '^CONFIG_CC_IS_CLANG=y' $(KDIR)/.config 2>/dev/null && echo LLVM=1)
+
 # Default target: build the module
 all:
-	$(MAKE) -C $(KDIR) M=$(PWD) modules
+	$(MAKE) $(KBUILD_COMPILER) -C $(KDIR) M=$(PWD) modules
 
 # Install module to system
 install: all
-	$(MAKE) -C $(KDIR) M=$(PWD) modules_install
+	$(MAKE) $(KBUILD_COMPILER) -C $(KDIR) M=$(PWD) modules_install
 	depmod -a
 
 # Clean build artifacts
 clean:
-	$(MAKE) -C $(KDIR) M=$(PWD) clean
+	$(MAKE) $(KBUILD_COMPILER) -C $(KDIR) M=$(PWD) clean
 	rm -f Module.symvers modules.order
 
 # Help target
