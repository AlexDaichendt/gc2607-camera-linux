-			ret = -EINVAL;
-			break;
-		}
-
-		/* Get calibrated register values from LUT */
 		{
-			const struct gc2607_gain_lut *lut = &gc2607_gain_table[ctrl->val];
+			unsigned int index = gc2607_gain_to_lut_index(ctrl->val);
+			const struct gc2607_gain_lut *lut = &gc2607_gain_table[index];
 
 			/* Write all 4 gain registers for proper calibration */
 			ret = gc2607_write_reg(gc2607, GC2607_REG_AGAIN_H, lut->reg2b3);
@@ -658,10 +686,31 @@ static int gc2607_s_ctrl(struct v4l2_ctrl *ctrl)
 			if (!ret) ret = gc2607_write_reg(gc2607, GC2607_REG_DGAIN_L, lut->reg20d);
 
 			if (!ret)
-				dev_dbg(&client->dev, "Set gain to LUT index %d\n", ctrl->val);
+				dev_dbg(&client->dev, "Set gain %d to LUT index %u\n",
+					ctrl->val, index);
 		}
 		break;
 
+	case V4L2_CID_DIGITAL_GAIN:
+		/*
+		 * The reference driver exposes digital gain allocation as a
+		 * no-op. Accept the HAL control so ISP-managed digital gain does
+		 * not fail the sensor update sequence.
+		 */
+		break;
+
+	case V4L2_CID_VBLANK:
+	{
+		u32 vts = gc2607->cur_mode->height + ctrl->val;
