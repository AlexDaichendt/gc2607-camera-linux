+bool PSysProcessor::isGc2607RawPaddingRequired(const std::map<Port, stream_t>& inputInfo) const {
+    if (!isGc2607Camera(mCameraId)) return false;
+
+    for (const auto& item : inputInfo) {
+        const stream_t& stream = item.second;
+        if (stream.format == V4L2_PIX_FMT_SGRBG10 && stream.width == kGc2607SourceWidth &&
+            stream.height == kGc2607SourceHeight) {
+            return true;
+        }
+    }
+
+    return false;
+}
+
+void PSysProcessor::adjustGc2607PsysInputInfo(std::map<Port, stream_t>* inputInfo) {
+    if (!inputInfo || !isGc2607RawPaddingRequired(*inputInfo)) return;
+
+    mUseGc2607RawPadding = true;
+    for (auto& item : *inputInfo) {
+        stream_t& stream = item.second;
+        if (stream.format == V4L2_PIX_FMT_SGRBG10 && stream.width == kGc2607SourceWidth &&
+            stream.height == kGc2607SourceHeight) {
+            LOG1("Enable GC2607 PSYS raw padding on port:%d (%dx%d -> %dx%d)", item.first,
+                 stream.width, stream.height, kGc2607PsysWidth, kGc2607PsysHeight);
+            stream.width = kGc2607PsysWidth;
+            stream.height = kGc2607PsysHeight;
+        }
+    }
+}
+
+shared_ptr<CameraBuffer> PSysProcessor::getGc2607PaddingBuffer() {
+    if (!mGc2607PaddingFreeBuffers.empty()) {
+        shared_ptr<CameraBuffer> buffer = mGc2607PaddingFreeBuffers.front();
+        mGc2607PaddingFreeBuffers.pop();
+        return buffer;
+    }
+
+    int size = CameraUtils::getFrameSize(V4L2_PIX_FMT_SGRBG10, kGc2607PsysWidth,
+                                         kGc2607PsysHeight, true);
+    shared_ptr<CameraBuffer> buffer =
+        CameraBuffer::create(mCameraId, BUFFER_USAGE_GENERAL, V4L2_MEMORY_USERPTR, size,
+                             mGc2607PaddingBufferIndex++, V4L2_PIX_FMT_SGRBG10,
+                             kGc2607PsysWidth, kGc2607PsysHeight);
+    CheckAndLogError(!buffer, nullptr, "%s, failed to allocate GC2607 padding buffer", __func__);
+    return buffer;
+}
+
+status_t PSysProcessor::padGc2607InputBuffers(CameraBufferPortMap* srcBuffers) {
+    if (!mUseGc2607RawPadding || !srcBuffers || srcBuffers->empty()) return OK;
+
+    CameraBufferPortMap originalBuffers;
+    CameraBufferPortMap paddedBuffers;
+    for (auto& item : *srcBuffers) {
+        shared_ptr<CameraBuffer> srcBuffer = item.second;
+        if (!srcBuffer || srcBuffer->getFormat() != V4L2_PIX_FMT_SGRBG10 ||
+            srcBuffer->getWidth() != kGc2607SourceWidth ||
+            srcBuffer->getHeight() != kGc2607SourceHeight) {
+            paddedBuffers[item.first] = srcBuffer;
+            continue;
+        }
+
+        shared_ptr<CameraBuffer> dstBuffer = getGc2607PaddingBuffer();
+        CheckAndLogError(!dstBuffer, NO_MEMORY, "%s, no GC2607 padding buffer", __func__);
+
+        ScopeMapping srcMapper(srcBuffer);
+        ScopeMapping dstMapper(dstBuffer);
+        auto* src = static_cast<unsigned char*>(srcMapper.getUserPtr());
+        auto* dst = static_cast<unsigned char*>(dstMapper.getUserPtr());
+        CheckAndLogError(!src || !dst, BAD_VALUE, "%s, failed to map GC2607 buffers", __func__);
+
+        const int srcStride = srcBuffer->getStride();
+        const int dstStride = dstBuffer->getStride();
+        const int copyBytes = kGc2607SourceWidth * kGc2607BytesPerPixel;
+        const int dstLeftOffset = kGc2607PadLeftPixels * kGc2607BytesPerPixel;
+        memset(dst, 0, dstBuffer->getBufferSize());
+
+        for (int row = 0; row < kGc2607SourceHeight; row++) {
+            unsigned char* dstRow = dst + ((row + kGc2607PadTopRows) * dstStride) + dstLeftOffset;
+            const unsigned char* srcRow = src + (row * srcStride);
+            MEMCPY_S(dstRow, dstStride - dstLeftOffset, srcRow, copyBytes);
+        }
+
+        dstBuffer->updateV4l2Buffer(*srcBuffer->getV4L2Buffer().Get());
+        dstBuffer->setBytesused(dstBuffer->getBufferSize());
+        dstBuffer->setSettingSequence(srcBuffer->getSettingSequence());
+
+        originalBuffers[item.first] = srcBuffer;
+        paddedBuffers[item.first] = dstBuffer;
+        item.second = dstBuffer;
+
+        LOG2("%s, padded GC2607 input seq:%d port:%d %dx%d/%d -> %dx%d/%d", __func__,
+             dstBuffer->getSequence(), item.first, srcBuffer->getWidth(), srcBuffer->getHeight(),
+             srcStride, dstBuffer->getWidth(), dstBuffer->getHeight(), dstStride);
+    }
+
+    if (!originalBuffers.empty()) {
+        int64_t sequence = originalBuffers.begin()->second->getSequence();
+        mGc2607OriginalInputBuffers[sequence] = originalBuffers;
+        mGc2607PaddedInputBuffers[sequence] = paddedBuffers;
+    }
+
+    return OK;
+}
+
+CameraBufferPortMap PSysProcessor::getGc2607OriginalInputBuffers(int64_t sequence) {
+    auto it = mGc2607OriginalInputBuffers.find(sequence);
+    if (it == mGc2607OriginalInputBuffers.end()) return CameraBufferPortMap();
+
+    CameraBufferPortMap buffers = it->second;
+    mGc2607OriginalInputBuffers.erase(it);
+    return buffers;
+}
+
+void PSysProcessor::recycleGc2607PaddingBuffers(int64_t sequence) {
+    auto it = mGc2607PaddedInputBuffers.find(sequence);
+    if (it == mGc2607PaddedInputBuffers.end()) return;
+
+    for (auto& item : it->second) {
+        if (item.second && item.second->getFormat() == V4L2_PIX_FMT_SGRBG10 &&
+            item.second->getWidth() == kGc2607PsysWidth &&
+            item.second->getHeight() == kGc2607PsysHeight) {
+            mGc2607PaddingFreeBuffers.push(item.second);
+        }
+    }
+    mGc2607PaddedInputBuffers.erase(it);
+}
